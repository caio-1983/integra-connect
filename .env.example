# Supabase (public anon key — safe to commit, matches the values already in .env)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Backend gateway — a single Fastify server that fronts BOTH the WhatsApp/
# Evolution admin surface AND the AI Runtime (see backend/README.md). This is
# just the frontend→backend base URL + HTTP auth key (GATEWAY_API_KEY on the
# backend). It is NOT an OpenAI/AI provider key — connecting WhatsApp needs this
# and nothing AI-related.
# Put real values in .env.local (gitignored), never here or in .env.
VITE_BACKEND_URL=http://localhost:8787
VITE_BACKEND_KEY=change-me-dev-key
# Legacy aliases — still honored as a fallback, but prefer VITE_BACKEND_* above.
# VITE_AI_GATEWAY_URL=
# VITE_AI_GATEWAY_KEY=

# Fase de venda da plataforma: 1 = Chat + Operações | 2 = + CRM + IA
VITE_PLATFORM_PHASE=1
