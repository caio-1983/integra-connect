# AI Runtime — copy to .env and fill in real values. Never commit .env.

# Server
PORT=8787
ALLOWED_ORIGIN=http://localhost:8080

# Auth between the Integra Connect frontend and this backend (NOT the OpenAI key).
# Generate any long random string, e.g.: openssl rand -hex 32
GATEWAY_API_KEY=change-me-dev-key

# Real OpenAI key — kept server-side only, never sent to the browser.
OPENAI_API_KEY=sk-...

# --- Sprint 011: Evolution API (WhatsApp) ---
# Base URL of your Evolution API instance and its global API key (apikey header).
EVOLUTION_API_URL=https://evolution.your-domain.com
EVOLUTION_API_KEY=your-evolution-global-api-key
# Public HTTPS URL of THIS backend, reachable by Evolution to deliver webhooks.
PUBLIC_BASE_URL=https://ai.your-domain.com
# Secret path segment appended to the webhook URL to authenticate inbound posts.
EVOLUTION_WEBHOOK_SECRET=change-me-webhook-secret

# --- Sprint 011: Supabase (service-role — server-side only, bypasses RLS) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
